<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title
      default="Typster — The Typst editor for writing that lands"
      suffix=" · Typster"
    >
      {assigns[:page_title]}
    </.live_title>
    <script>
      (() => {
        const key = "phx:theme";
        const root = document.documentElement;

        const getStoredTheme = () => {
          try {
            return localStorage.getItem(key);
          } catch {
            return null;
          }
        };

        const storeTheme = (theme) => {
          try {
            if (theme === "system") {
              localStorage.removeItem(key);
            } else {
              localStorage.setItem(key, theme);
            }
          } catch {}
        };

        const setTheme = (theme) => {
          const next = theme === "light" || theme === "dark" ? theme : "system";

          if (next === "system") {
            root.removeAttribute("data-theme");
          } else {
            root.setAttribute("data-theme", next);
          }

          storeTheme(next);
        };

        setTheme(getStoredTheme());
        window.addEventListener("storage", (e) => e.key === key && setTheme(e.newValue));
        window.addEventListener("phx:set-theme", (e) => {
          const source = e.target instanceof Element ? e.target.closest("[data-phx-theme]") : null;
          setTheme(source && source.dataset.phxTheme);
        });
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="module" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        window.mkSwitchTab = function(btn) {
          const key = btn.dataset.tab;
          document.querySelectorAll('.mk-demo-tab').forEach(t => t.classList.toggle('is-active', t === btn));
          document.querySelectorAll('.mk-demo-panel').forEach(p => p.classList.toggle('is-active', p.dataset.panel === key));
        };
      })();
    </script>
  </head>
  <body class="mk-body">
    <.mk_nav current_scope={@current_scope}>
      <:nav_links>
        <a href="#features">Features</a>
        <a href="#pricing">Pricing</a>
        <a href="#faq">FAQ</a>
        <a href="https://typst.app/docs" target="_blank">Docs</a>
      </:nav_links>
    </.mk_nav>
    {@inner_content}
  </body>
</html>

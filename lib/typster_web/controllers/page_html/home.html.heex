<%!-- Hero ─────────────────────────────────────────────────────────── --%>
<section class="mk-hero">
  <div class="mk-pill">
    <span class="mk-pill-dot"></span>
    v1.0 · Public beta is live
  </div>
  <h1>The <em>Typst</em> editor<br/>for writing that ships.</h1>
  <p class="mk-hero-sub">
    A polished, three-pane Typst editor with live preview, keyboard-first UX,
    and zero setup. Compile beautiful PDFs from your browser.
  </p>
  <div class="mk-hero-ctas">
    <.link navigate={~p"/users/register"} class="mk-btn mk-btn-primary mk-btn-lg">
      Start writing — it's free
      <i data-lucide="arrow-right" class="mk-icon-14"></i>
    </.link>
    <a href="https://github.com/typster/typster" class="mk-btn mk-btn-outline mk-btn-lg">
      <i data-lucide="github" class="mk-icon-16"></i>
      Star on GitHub
    </a>
  </div>
  <p class="mk-hero-fine">No credit card · 3 projects free · 100 MB storage</p>

  <%!-- Mock editor --%>
  <div class="mk-art">
    <div class="mk-mock">
      <div class="mk-mock-bar">
        <span class="mk-mock-dot" style="background:#fb7185"></span>
        <span class="mk-mock-dot" style="background:#fbbf24"></span>
        <span class="mk-mock-dot" style="background:#34d399"></span>
        <span style="margin-left:10px;font-size:12px">quarterly-report / main.typ</span>
        <span style="margin-left:auto;display:flex;gap:6px">
          <span style="padding:2px 8px;border-radius:4px;background:#eef2ff;color:#4f46e5;font-size:11px;font-weight:500">Auto-saved</span>
          <span style="padding:2px 8px;border-radius:4px;background:#f0fdf4;color:#16a34a;font-size:11px;font-weight:500">● Compiled</span>
        </span>
      </div>
      <aside class="mk-mock-side">
        <div class="mk-mock-side-h">Files</div>
        <div class="mk-mock-row active">
          <i data-lucide="file" class="mk-icon-12"></i>
          main.typ
        </div>
        <div class="mk-mock-row">
          <i data-lucide="file" class="mk-icon-12"></i>
          sections/intro.typ
        </div>
        <div class="mk-mock-row">
          <i data-lucide="file" class="mk-icon-12"></i>
          sections/data.typ
        </div>
        <div class="mk-mock-row">
          <i data-lucide="file" class="mk-icon-12"></i>
          refs.bib
        </div>
        <div class="mk-mock-side-h" style="margin-top:12px">Assets</div>
        <div class="mk-mock-row">
          <i data-lucide="image" class="mk-icon-12"></i>
          cover.png
        </div>
      </aside>
      <div class="mk-mock-src">
        <div class="mk-mock-ln"><span class="mk-mock-gn">1</span><span class="mk-tok-comment">// main.typ — quarterly report</span></div>
        <div class="mk-mock-ln"><span class="mk-mock-gn">2</span><span class="mk-tok-keyword">#set</span><span> page(margin: </span><span class="mk-tok-string">1in</span><span>, paper: </span><span class="mk-tok-string">"a4"</span><span>)</span></div>
        <div class="mk-mock-ln"><span class="mk-mock-gn">3</span><span class="mk-tok-keyword">#set</span><span> text(font: </span><span class="mk-tok-string">"Inter"</span><span>, size: </span><span class="mk-tok-string">11pt</span><span>)</span></div>
        <div class="mk-mock-ln"><span class="mk-mock-gn">4</span></div>
        <div class="mk-mock-ln"><span class="mk-mock-gn">5</span><span class="mk-tok-heading">= Quarterly Report</span></div>
        <div class="mk-mock-ln"><span class="mk-mock-gn">6</span><span class="mk-tok-keyword">#datetime</span><span>.today().display()</span></div>
        <div class="mk-mock-ln"><span class="mk-mock-gn">7</span></div>
        <div class="mk-mock-ln"><span class="mk-mock-gn">8</span><span class="mk-tok-heading">== Summary</span></div>
        <div class="mk-mock-ln"><span class="mk-mock-gn">9</span></div>
        <div class="mk-mock-ln"><span class="mk-mock-gn">10</span><span>This quarter, </span><span class="mk-tok-em">*Typster*</span><span> shipped</span></div>
        <div class="mk-mock-ln"><span class="mk-mock-gn">11</span><span>its first public beta. We grew</span></div>
        <div class="mk-mock-ln"><span class="mk-mock-gn">12</span><span>to </span><span class="mk-tok-em">_2,400 weekly users_</span><span> and</span></div>
        <div class="mk-mock-ln"><span class="mk-mock-gn">13</span><span>processed 18k compile jobs.</span></div>
        <div class="mk-mock-ln"><span class="mk-mock-gn">14</span></div>
        <div class="mk-mock-ln"><span class="mk-mock-gn">15</span><span class="mk-tok-heading">== Highlights</span></div>
        <div class="mk-mock-ln"><span class="mk-mock-gn">16</span></div>
        <div class="mk-mock-ln"><span class="mk-mock-gn">17</span><span>- Three-pane editor</span></div>
        <div class="mk-mock-ln"><span class="mk-mock-gn">18</span><span>- Live preview</span></div>
        <div class="mk-mock-ln"><span class="mk-mock-gn">19</span><span>- Magic-link auth</span></div>
      </div>
      <div class="mk-mock-pdf">
        <div class="mk-mock-pdf-page">
          <div class="mk-mock-pdf-h1">Quarterly Report</div>
          <div class="mk-mock-pdf-date">April 30, 2026</div>
          <div class="mk-mock-pdf-h2">Summary</div>
          <p class="mk-mock-pdf-p">This quarter, <b>Typster</b> shipped its first public beta. We grew to <i>2,400 weekly users</i> and processed over 18k compile jobs.</p>
          <div class="mk-mock-pdf-h2">Highlights</div>
          <p class="mk-mock-pdf-p">• Three-pane editor with live preview<br/>• Magic-link authentication<br/>• Keyboard-first command palette<br/>• Cloud projects &amp; auto-save</p>
        </div>
      </div>
    </div>
  </div>
</section>

<%!-- Stats ────────────────────────────────────────────────────────── --%>
<div class="mk-stats mk-reveal">
  <div class="mk-stats-grid mk-reveal-group">
    <div class="mk-stat">
      <div class="mk-stat-n">2<span>,400</span></div>
      <div class="mk-stat-l">Weekly active writers</div>
    </div>
    <div class="mk-stat">
      <div class="mk-stat-n">18<span>k</span></div>
      <div class="mk-stat-l">Compile jobs processed</div>
    </div>
    <div class="mk-stat">
      <div class="mk-stat-n"><span>~</span>200ms</div>
      <div class="mk-stat-l">Median compile time</div>
    </div>
    <div class="mk-stat">
      <div class="mk-stat-n">100<span>%</span></div>
      <div class="mk-stat-l">Browser-based, zero install</div>
    </div>
  </div>
</div>

<%!-- How it works ──────────────────────────────────────────────────── --%>
<section class="mk-section mk-hiw-section">
  <div class="mk-container">
    <p class="mk-eyebrow mk-reveal">How it works</p>
    <h2 class="mk-section-h mk-reveal">From idea to PDF in seconds.</h2>
    <div class="mk-hiw-steps mk-reveal-group">
      <div class="mk-hiw-step">
        <div class="mk-hiw-num">01</div>
        <h3 class="mk-hiw-title">Write</h3>
        <p class="mk-hiw-desc">Open Typster and start writing Typst markup — no install, no configuration. Just a blank file and your ideas.</p>
      </div>
      <div class="mk-hiw-step">
        <div class="mk-hiw-num">02</div>
        <h3 class="mk-hiw-title">Compile</h3>
        <p class="mk-hiw-desc">Hit save. The preview updates live in the right pane. Edge-rendered, typically under 200 ms.</p>
      </div>
      <div class="mk-hiw-step">
        <div class="mk-hiw-num">03</div>
        <h3 class="mk-hiw-title">Share</h3>
        <p class="mk-hiw-desc">Download the PDF or copy a read-only link. Recipients open it in their browser — no account needed.</p>
      </div>
    </div>
  </div>
</section>

<%!-- Features ─────────────────────────────────────────────────────── --%>
<section id="features" class="mk-section mk-section-tinted">
  <div class="mk-container">
    <p class="mk-eyebrow mk-reveal">Why Typster</p>
    <h2 class="mk-section-h mk-reveal">Built for writers who care about output.</h2>
    <p class="mk-section-sub mk-reveal">Typst is the new TeX. Typster is the IDE that makes it feel inevitable.</p>
    <div class="mk-feat-grid mk-reveal-group">
      <div class="mk-feat">
        <div class="mk-feat-icon"><i data-lucide="zap"></i></div>
        <h3>Compile in milliseconds</h3>
        <p>Edge-rendered Typst compilation. Save → see the PDF before your finger leaves ⌘S.</p>
      </div>
      <div class="mk-feat">
        <div class="mk-feat-icon"><i data-lucide="command"></i></div>
        <h3>Keyboard-first</h3>
        <p>Every action sits behind ⌘⇧P. New file, save, search, switch project — never reach for the mouse.</p>
      </div>
      <div class="mk-feat">
        <div class="mk-feat-icon"><i data-lucide="eye"></i></div>
        <h3>Live three-pane layout</h3>
        <p>Files · source · preview, all on screen at once. Resizable handles, persistent layout.</p>
      </div>
      <div class="mk-feat">
        <div class="mk-feat-icon"><i data-lucide="cloud-upload"></i></div>
        <h3>Cloud projects</h3>
        <p>Auto-saved to the cloud. Works on every device, no install, no setup required.</p>
      </div>
      <div class="mk-feat">
        <div class="mk-feat-icon"><i data-lucide="share-2"></i></div>
        <h3>Shareable links</h3>
        <p>Send a read-only link. Recipients open the PDF in-browser, no account needed.</p>
      </div>
      <div class="mk-feat">
        <div class="mk-feat-icon"><i data-lucide="type"></i></div>
        <h3>Bring your fonts</h3>
        <p>Upload TTF/OTF assets per project. Typst reads them on every compile, exactly as authored.</p>
      </div>
    </div>
  </div>
</section>

<%!-- Keyboard band ────────────────────────────────────────────────── --%>
<section class="mk-section mk-kb-band">
  <p class="mk-eyebrow">Keyboard-first</p>
  <h2 class="mk-section-h">Touch the mouse less.</h2>
  <p class="mk-section-sub">Every command, two keystrokes away. Designed for writers who think in shortcuts.</p>
  <div class="mk-kb-grid mk-reveal-group">
    <div class="mk-kb-row">
      <span class="mk-kb-label">Save document</span>
      <span class="mk-kb-keys"><kbd class="mk-kb-key">⌘</kbd><kbd class="mk-kb-key">S</kbd></span>
    </div>
    <div class="mk-kb-row">
      <span class="mk-kb-label">Command palette</span>
      <span class="mk-kb-keys"><kbd class="mk-kb-key">⌘</kbd><kbd class="mk-kb-key">⇧</kbd><kbd class="mk-kb-key">P</kbd></span>
    </div>
    <div class="mk-kb-row">
      <span class="mk-kb-label">Toggle sidebar</span>
      <span class="mk-kb-keys"><kbd class="mk-kb-key">⌘</kbd><kbd class="mk-kb-key">B</kbd></span>
    </div>
    <div class="mk-kb-row">
      <span class="mk-kb-label">Toggle preview</span>
      <span class="mk-kb-keys"><kbd class="mk-kb-key">⌘</kbd><kbd class="mk-kb-key">E</kbd></span>
    </div>
    <div class="mk-kb-row">
      <span class="mk-kb-label">Search in file</span>
      <span class="mk-kb-keys"><kbd class="mk-kb-key">⌘</kbd><kbd class="mk-kb-key">/</kbd></span>
    </div>
    <div class="mk-kb-row">
      <span class="mk-kb-label">New file</span>
      <span class="mk-kb-keys"><kbd class="mk-kb-key">⌘</kbd><kbd class="mk-kb-key">N</kbd></span>
    </div>
    <div class="mk-kb-row">
      <span class="mk-kb-label">Close file</span>
      <span class="mk-kb-keys"><kbd class="mk-kb-key">⌘</kbd><kbd class="mk-kb-key">W</kbd></span>
    </div>
    <div class="mk-kb-row">
      <span class="mk-kb-label">Switch to file 1–9</span>
      <span class="mk-kb-keys"><kbd class="mk-kb-key">⌘</kbd><kbd class="mk-kb-key">1-9</kbd></span>
    </div>
  </div>
</section>


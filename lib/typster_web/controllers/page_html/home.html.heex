            <div class="mk-mock-ln"><span class="mk-mock-gn">6</span></div>
            <div class="mk-mock-ln"><span class="mk-mock-gn">7</span><span class="mk-tok-keyword">#table</span><span>(columns: (1fr, auto, auto),</span></div>
            <div class="mk-mock-ln"><span class="mk-mock-gn">8</span><span>  </span><span class="mk-tok-string">[Description]</span><span>, </span><span class="mk-tok-string">[Qty]</span><span>, </span><span class="mk-tok-string">[Amount]</span><span>,</span></div>
            <div class="mk-mock-ln"><span class="mk-mock-gn">9</span><span>  </span><span class="mk-tok-string">[Design work]</span><span>, </span><span class="mk-tok-string">[8h]</span><span>, </span><span class="mk-tok-string">[$960]</span><span>,</span></div>
            <div class="mk-mock-ln"><span class="mk-mock-gn">10</span><span>  </span><span class="mk-tok-string">[Development]</span><span>, </span><span class="mk-tok-string">[16h]</span><span>, </span><span class="mk-tok-string">[$2,400]</span><span>,</span></div>
            <div class="mk-mock-ln"><span class="mk-mock-gn">11</span><span>)</span></div>
            <div class="mk-mock-ln"><span class="mk-mock-gn">12</span></div>
            <div class="mk-mock-ln"><span class="mk-mock-gn">13</span><span class="mk-tok-em">*Total: $3,360*</span></div>
          </div>
          <div class="mk-demo-preview">
            <div class="mk-mock-pdf-page">
              <div class="mk-mock-pdf-h1">Invoice #042</div>
              <div class="mk-mock-pdf-date">April 30, 2026</div>
              <p class="mk-mock-pdf-p" style="margin-bottom:4px"><b>From:</b> Jane Smith Consulting<br/><b>To:</b> Acme Corp</p>
              <table class="mk-demo-table" style="margin-top:12px"><tr><th>Description</th><th>Qty</th><th>Amount</th></tr><tr><td>Design work</td><td>8h</td><td>$960</td></tr><tr><td>Development</td><td>16h</td><td>$2,400</td></tr></table>
              <p class="mk-mock-pdf-p" style="margin-top:12px;font-weight:700;font-size:11pt">Total: $3,360</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<%!-- ── END SECTION 3 ──────────────────────────────────────────────────── --%>

<%!-- ── SECTION 4: Use cases — remove this block if cutting ──────────── --%>
<section class="mk-section mk-usecase-section">
  <div class="mk-container">
    <p class="mk-eyebrow mk-reveal">Use cases</p>
    <h2 class="mk-section-h mk-reveal">Whatever you write, Typst handles it.</h2>
    <div class="mk-usecase-grid mk-reveal-group">
      <div class="mk-usecase">
        <div class="mk-usecase-icon">🎓</div>
        <h3>Academic papers</h3>
        <p>Multi-column layouts, citations, math equations, and bibliography — exactly as journals require.</p>
      </div>
      <div class="mk-usecase">
        <div class="mk-usecase-icon">📄</div>
        <h3>CVs & Resumes</h3>
        <p>Pixel-perfect one-pagers. Update once, every position reflows without fighting Word styles.</p>
      </div>
      <div class="mk-usecase">
        <div class="mk-usecase-icon">📊</div>
        <h3>Technical reports</h3>
        <p>Tables, code blocks, cross-references, and version-controlled source. No more PDF drift.</p>
      </div>
      <div class="mk-usecase">
        <div class="mk-usecase-icon">🧾</div>
        <h3>Invoices & contracts</h3>
        <p>Consistent branded documents generated from structured data. No design tool required.</p>
      </div>
      <div class="mk-usecase">
        <div class="mk-usecase-icon">📝</div>
        <h3>Lecture notes</h3>
        <p>Math-heavy slides and handouts that actually look professional. Export to PDF in seconds.</p>
      </div>
    </div>
  </div>
</section>
<%!-- ── END SECTION 4 ──────────────────────────────────────────────────── --%>

